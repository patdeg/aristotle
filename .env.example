# ============================================================================
# Aristotle — your child's AI mentor
# Copy this file to .env and fill in your values. NEVER commit .env.
# ============================================================================

# --- Mentor identity (change if you want a different philosopher) ------------
# The name shown on worksheets and in email signatures.
# Examples: Aristotle, Socrates, Plato, Hypatia, Confucius, Ada
MENTOR_NAME=Aristotle

# From: address for outgoing mail. Use your own domain (see README → Email setup).
MENTOR_EMAIL=aristotle@yourdomain.example

# --- Your child -------------------------------------------------------------
CHILD_NAME=
CHILD_GRADE=
CHILD_EMAIL=
PARENT_EMAIL=

# --- Subjects ---------------------------------------------------------------
# Comma-separated list. Aristotle generates one section per subject per run.
# Common values: math, science, social_studies, language_arts, foreign_language
SUBJECTS=math

# Per-subject Canvas course ID. Only fill in the subjects you listed above.
# Find the ID in the Canvas URL when viewing the course:
#   https://<district>.instructure.com/courses/184581  → 184581
CANVAS_COURSE_MATH=
CANVAS_COURSE_SCIENCE=
CANVAS_COURSE_SOCIAL_STUDIES=
CANVAS_COURSE_LANGUAGE_ARTS=
CANVAS_COURSE_FOREIGN_LANGUAGE=

# --- Canvas LMS (only if your school uses Canvas) ---------------------------
# Get a personal access token from your parent-observer account:
#   Account → Settings → "+ New Access Token"
CANVAS_API_KEY=
CANVAS_BASE_URL=https://YOUR_DISTRICT.instructure.com/api/v1
CANVAS_STUDENT_ID=

# --- Image generation (optional) --------------------------------------------
# Used by generate_illustration.py. Leave blank to skip illustrations.
DEMETERICS_API_KEY=

# --- Email SMTP (any provider — Migadu, Fastmail, Gmail app password, etc.) -
# The weekly script sends mail via the `himalaya` CLI. Configure an account in
# ~/.config/himalaya/config.toml whose name matches HIMALAYA_ACCOUNT below.
# See README → "Email setup" for a recommended domain + Migadu walkthrough.
HIMALAYA_ACCOUNT=aristotle
